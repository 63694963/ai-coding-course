        weakestKey === "context" ? "背景不足：\n请写活动延期通知。\n\nAI 不知道对象是客户、同事，还是供应商。" :
        weakestKey === "boundary" ? "边界不足：\n做一个会议纪要工具。\n\nAI 可能默认加登录、上传、协作等第一版不需要的功能。" :
        "验证不足：\n帮我做完。\n\nAI 不知道怎样算合格，你也不知道应该检查哪里。";
    } else if (useful >= 82) {
      tokenVerdict.textContent = "分配健康";
      tokenAdvice.textContent = "关键 Token 都花在目标、背景、边界和验证上。AI 更容易一次走到正确方向。";
      tokenExample.textContent = "目标：安排 3 天杭州旅行。\n背景：两人、预算 3000、想轻松。\n边界：不要太多景点，晚上不要太晚。\n验证：按上午/下午/晚上输出。";
    } else {
      tokenVerdict.textContent = "还能更聚焦";
      tokenAdvice.textContent = "可用信息占 " + useful + " 个格子。可以继续删掉无关材料，把空间让给目标、背景、边界或验证。";
      tokenExample.textContent = "保留会影响结果的信息：对象、预算、限制、输出格式。\n删掉不影响当前任务的材料：历史闲聊、无关介绍、过早的复杂功能。";
    }
  }
  tokenInputs.forEach(function (input) { input.addEventListener("input", updateTokens); });
  updateTokens();

  var checks = document.querySelectorAll("#checks input");
  var checkResult = document.getElementById("checkResult");
  function updateChecks() {
    var done = Array.prototype.filter.call(checks, function (input) { return input.checked; }).length;
    var text = done + "/4";
    var msg = done === 4 ? "这次 AI 使用已经形成了可复用推进。" :
      done >= 2 ? "已经开始推进，但还可以补上沉淀或交付。" :
      "还没有形成可复用能力。";
    checkResult.textContent = "已勾选 " + text + "：" + msg;
  }
  checks.forEach(function (input) { input.addEventListener("change", updateChecks); });
  updateChecks();

  var diagnosisCopy = {
    all: {
      title: "正确：这句话几乎所有关键条件都缺",
      body: "它听起来像一个需求，但目标、背景、边界、格式、验证都不清楚。AI 只能自己补脑，补错了你还要返工。"
    },
    goal: {
      title: "目标确实缺，但不是唯一问题",
      body: "“方便销售用”不是可检查目标。还要继续补客户类型、第一版边界、输出格式和判断标准。"
    },
    context: {
      title: "背景确实缺，但不是唯一问题",
      body: "AI 不知道销售怎么跟进客户，也不知道客户类型。除此之外，边界、格式和验证也需要补。"
