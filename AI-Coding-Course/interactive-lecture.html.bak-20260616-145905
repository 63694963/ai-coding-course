    format: {
      title: "格式确实缺，但不是唯一问题",
      body: "表格、页面、字段清单、Excel 模板会导向不同输出。除此之外，目标、背景、边界也不清楚。"
    },
    check: {
      title: "验证确实缺，但不是唯一问题",
      body: "“简单”“方便”都需要检查标准。比如销售看完字段不需要再问、3 分钟内能填完。"
    }
  };
  var diagnosisResult = document.getElementById("diagnosisResult");
  function setPanel(panel, title, body) {
    panel.innerHTML = "";
    var strong = document.createElement("strong");
    var p = document.createElement("p");
    strong.textContent = title;
    p.textContent = body;
    panel.appendChild(strong);
    panel.appendChild(p);
  }
  document.querySelectorAll("#diagnosisChoices .choice-btn").forEach(function (button) {
    button.addEventListener("click", function () {
      var answer = button.getAttribute("data-answer");
      document.querySelectorAll("#diagnosisChoices .choice-btn").forEach(function (btn) {
        btn.classList.remove("correct", "wrong", "active");
      });
      button.classList.add(answer === "all" ? "correct" : "wrong");
      var correct = document.querySelector('#diagnosisChoices .choice-btn[data-answer="all"]');
      if (correct) correct.classList.add("correct");
      setPanel(diagnosisResult, diagnosisCopy[answer].title, diagnosisCopy[answer].body);
    });
  });

  var contextData = {
    missing: {
      output: "亲爱的客户，非常抱歉给您带来不便。我们会尽快处理相关问题，并持续优化服务质量。感谢您的理解与支持。",
      title: "问题：输出很礼貌，但很空",
      lesson: "AI 不知道客户为什么不满，也不知道能承诺什么，只能生成通用道歉话术。"
    },
    wrong: {
      output: "关于价格问题，我们理解您的顾虑。后续会结合您的采购规模，尽量提供更有竞争力的方案。",
      title: "问题：AI 会认真沿着错误背景写",
      lesson: "如果真实原因是交付延迟，这封邮件方向就错了。错背景比缺背景更危险。"
    },
    tooMuch: {
      output: "结合贵司多年合作历史、我司产品体系、近期市场环境和双方沟通记录，我们建议从多方面提升协作体验。",
      title: "问题：重点被淹没",
      lesson: "材料很多，但重点不清。AI 可能写得很全面，却没有解决这一次具体投诉。"
    },
    focused: {
      output: "王经理，抱歉这批货比原计划晚到 2 天。今天 17:00 前我们会给您准确物流节点。现在不承诺补偿金额，但会在确认责任后给出处理方案。",
      title: "效果：方向更稳，承诺边界清楚",
      lesson: "对象、原因、下一步、不能承诺的内容都清楚，AI 更容易写出可用版本。"
    },
    feedback: {
      output: "上一版太像模板，且承诺了“尽快补偿”。请改成更具体：说明延迟 2 天、今天 17:00 前同步物流、不承诺未知补偿、语气负责但不要过度道歉。",
      title: "效果：反馈也变成了上下文",
      lesson: "告诉 AI 哪一句不对、为什么不对、下一版要怎么改，下一轮才会更准。"
    }
  };
  var contextOutput = document.getElementById("contextOutput");
  var contextLesson = document.getElementById("contextLesson");
  function updateContext(key) {
    var item = contextData[key];
    contextOutput.textContent = item.output;
    setPanel(contextLesson, item.title, item.lesson);
    document.querySelectorAll("#contextScenarios .scenario-btn").forEach(function (button) {
      button.classList.toggle("active", button.getAttribute("data-context") === key);
    });
  }
  document.querySelectorAll("#contextScenarios .scenario-btn").forEach(function (button) {
    button.addEventListener("click", function () { updateContext(button.getAttribute("data-context")); });
  });
  updateContext("missing");

  var sortLabels = { input: "input", output: "output", backup: "backup", rules: "rules" };
  var sortItems = Array.prototype.slice.call(document.querySelectorAll("#sortBoard .sort-item"));
  var sortOutput = document.getElementById("sortOutput");
  var sortResult = document.getElementById("sortResult");
  sortItems.forEach(function (item) {
    var actions = item.querySelector(".sort-actions");
    Object.keys(sortLabels).forEach(function (key) {
      var btn = document.createElement("button");
      btn.type = "button";
      btn.textContent = sortLabels[key];
      btn.addEventListener("click", function () {
        item.setAttribute("data-choice", key);
        actions.querySelectorAll("button").forEach(function (other) {
          other.classList.toggle("active", other === btn);
        });
        updateSort();
      });
      actions.appendChild(btn);
    });
  });
  function updateSort() {
    var groups = { input: [], output: [], backup: [], rules: [] };
    var correct = 0;
    sortItems.forEach(function (item) {
      var choice = item.getAttribute("data-choice");
      var name = item.querySelector("span").textContent;
      if (choice) groups[choice].push(name);
      if (choice && choice === item.getAttribute("data-correct")) correct += 1;
    });
    sortOutput.textContent = Object.keys(groups).map(function (key) {
      return key + "/\n  " + (groups[key].length ? groups[key].join("\n  ") : "未选择");
    }).join("\n\n");
    var body = correct === sortItems.length ? "分类完成。这个结构让 AI 清楚读取材料、写入成果、遵守规则，并且保留回退路径。" :
      "还有材料没有归类正确。课堂上可以追问：这是给 AI 看的输入，还是 AI 生成的输出？是规则，还是备份？";
    setPanel(sortResult, correct + "/" + sortItems.length + " 正确", body);
  }
  updateSort();

  var harnessData = {
    profile: {
      output: "写进个人 Profile：\n\n默认保持简洁、直接、讲逻辑。\n不要为了迎合我而隐藏问题。\n如果需求有歧义，先说明不同理解和取舍，再问我确认。\n如果任务很小，可以直接做，但完成后说明检查点。",
      title: "放在个人 Profile",
      lesson: "这是长期工作习惯，适合跨项目复用。它不规定某个业务怎么做，而是规定 AI 应该以什么方式做事。"
    },
    rules: {
      output: "写进项目规则：\n\n这个课程项目默认面向没有技术背景的人。\n少用术语，多用生活例子。\n反面案例要像真实用户会说的话。\n新增内容必须适合投屏展示，文字不能过密。",
      title: "放在项目规则",
      lesson: "这是当前项目的边界和风格。换一个项目，这些规则可能就不适用了。"
    },
    skill: {
      output: "沉淀成 Skill：\n\n当我让你生成课程展示页时：\n1. 先判断受众和课程主线。\n2. 每个概念配一个生活例子。\n3. 每个章节只表达一个重点。\n4. 生成后检查是否适合投屏。\n5. 最后列出我应该人工确认的地方。",
      title: "沉淀成 Skill",
      lesson: "这是某类重复任务的 SOP。判断标准很简单：第三次解释同一套流程，就该沉淀。"
    },
    conflict: {
      output: "让 AI 暴露冲突：\n\n这里有两个要求冲突：\n1. 项目规则要求少用术语。\n2. 当前任务要求保留专业名词。\n\n我建议保留必要名词，但每个名词后面加一句通俗解释。\n是否按这个方向处理？",
      title: "先暴露冲突，不要自己猜",
      lesson: "好的 Harness 不是规则越多越好，而是让 AI 知道遇到冲突时该停下来说明。"
    }
  };
  var harnessOutput = document.getElementById("harnessOutput");
  var harnessLesson = document.getElementById("harnessLesson");
  function updateHarness(key) {
    var item = harnessData[key];
    harnessOutput.textContent = item.output;
    setPanel(harnessLesson, item.title, item.lesson);
    document.querySelectorAll("#harnessChoices .project-option").forEach(function (button) {
      button.classList.toggle("active", button.getAttribute("data-harness") === key);
    });
  }
  document.querySelectorAll("#harnessChoices .project-option").forEach(function (button) {
    button.addEventListener("click", function () { updateHarness(button.getAttribute("data-harness")); });
  });
  updateHarness("profile");

  var projectData = {
    minutes: {
      output: "我想先做一个最简单的会议纪要整理工具。\n第一版只处理已经转成文字的会议记录，不处理录音。\n使用者把文字粘贴进去，点击按钮后，输出三部分：会议摘要、关键决定、待办事项。\n先不要做登录、上传、多人协作。\n判断标准：输出内容能直接发给参会人确认。",
      title: "讲解重点：先砍掉录音和上传",
      lesson: "这能让第一版从复杂系统变成一个文本整理工具，适合小白现场理解。"
    },
    customer: {
      output: "我想先做一个客户回访表单。\n使用者是销售，目标是记录老客户状态和下一步跟进。\n第一版只包含字段、填写说明和示例记录，不接 CRM，不做自动提醒。\n判断标准：销售看完字段就知道怎么填，并能在 3 分钟内完成一条记录。",
      title: "讲解重点：把“方便”变成检查标准",
      lesson: "不要只说简单好用，要说谁用、多久填完、看完是否还需要解释。"
    },
    course: {
      output: "我想先做一个课程展示页面。\n受众是完全没有编程基础的小白。\n页面要包含课程主线、生活案例、好坏 Prompt 对比、课堂互动和行动路径。\n先不要做登录、后台、数据保存。\n判断标准：投屏时 10 分钟内能讲清一个概念，并让学生完成一个小练习。",
      title: "讲解重点：课程页面也可以是 AI Coding",
      lesson: "这能把内容制作、案例设计和前端页面连接起来，贴合当前课堂本身。"
    },
    review: {
      output: "我想先做一个方案风险检查器。\n使用者把活动方案粘贴进去，页面按三个角度输出问题：目标是否清楚、步骤是否可落地、明显风险。\n第一版不做文件上传、团队协作和历史记录。\n判断标准：输出必须直接指出问题，不要客套，并给出下一步修改建议。",
      title: "讲解重点：让 AI 挑问题要明确标准",
      lesson: "这对应 Prompt 章节的“给方案提建议”案例，可以自然过渡到小工具。"
    }
  };
  var projectOutput = document.getElementById("projectOutput");
  var projectLesson = document.getElementById("projectLesson");
  function updateProject(key) {
    var item = projectData[key];
    projectOutput.textContent = item.output;
    setPanel(projectLesson, item.title, item.lesson);
    document.querySelectorAll("#projectChoices .project-option").forEach(function (button) {
      button.classList.toggle("active", button.getAttribute("data-project") === key);
    });
  }
  document.querySelectorAll("#projectChoices .project-option").forEach(function (button) {
    button.addEventListener("click", function () { updateProject(button.getAttribute("data-project")); });
  });
  updateProject("minutes");

  document.getElementById("modeBtn").addEventListener("click", function () {
    document.body.classList.toggle("lesson-mode");
  });
  document.getElementById("topBtn").addEventListener("click", function () {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });

  document.addEventListener("keydown", function (event) {
    if (event.key === "Escape") document.body.classList.remove("lesson-mode");
    if (event.key === "ArrowDown" || event.key === "PageDown") {
      event.preventDefault();
      var next = sections.find(function (section) { return section.offsetTop > window.scrollY + 20; });
      if (next) next.scrollIntoView({ behavior: "smooth" });
    }
    if (event.key === "ArrowUp" || event.key === "PageUp") {
      event.preventDefault();
      var previous = sections.slice().reverse().find(function (section) { return section.offsetTop < window.scrollY - 20; });
      if (previous) previous.scrollIntoView({ behavior: "smooth" });
    }
  });
})();
</script>
</body>
</html>
