<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Coding 交互讲解 · 从 Token 到四种能力</title>
<link rel="icon" href="data:,">
<style>
:root {
  --bg: #050609;
  --bg2: #0c1017;
  --panel: rgba(255,255,255,.055);
  --panel2: rgba(255,255,255,.082);
  --line: rgba(255,255,255,.12);
  --line2: rgba(255,255,255,.22);
  --text: #f3f1ea;
  --muted: #a9adb7;
  --faint: #6f7480;
  --blue: #4da3ff;
  --cyan: #4ed7c5;
  --green: #74d889;
  --gold: #f0b84f;
  --red: #ff6f61;
  --violet: #b790ff;
  --shadow: 0 20px 60px rgba(0,0,0,.32);
  --nav-h: 58px;
  --max: 1180px;
}

* { box-sizing: border-box; }
html { scroll-behavior: smooth; background: var(--bg); }
body {
  margin: 0;
  color: var(--text);
  background:
    radial-gradient(circle at 12% 8%, rgba(77,163,255,.18), transparent 28rem),
    radial-gradient(circle at 90% 28%, rgba(78,215,197,.11), transparent 26rem),
    linear-gradient(180deg, #050609 0%, #080a0f 44%, #050609 100%);
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", "Noto Sans SC", "Helvetica Neue", Arial, sans-serif;
  line-height: 1.72;
  -webkit-font-smoothing: antialiased;
}

button, input { font: inherit; }
button { cursor: pointer; }
button:focus-visible, input:focus-visible {
  outline: 2px solid rgba(78,215,197,.88);
  outline-offset: 3px;
}

.topbar {
  position: fixed;
  inset: 0 0 auto;
  height: var(--nav-h);
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 14px;
  align-items: center;
  padding: 0 clamp(14px, 3vw, 34px);
  z-index: 50;
  background: rgba(5,6,9,.72);
  backdrop-filter: blur(18px);
  border-bottom: 1px solid rgba(255,255,255,.08);
}
.brand {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-weight: 760;
  letter-spacing: 0;
  white-space: nowrap;
}
.mark {
  width: 22px;
  height: 22px;
  border-radius: 7px;
  background:
    linear-gradient(135deg, var(--blue), var(--cyan));
  box-shadow: 0 0 28px rgba(77,163,255,.45);
}
.nav {
  display: flex;
  gap: 6px;
  overflow-x: auto;
  scrollbar-width: none;
  min-width: 0;
}
.nav::-webkit-scrollbar { display: none; }
.nav a {
  color: var(--faint);
  text-decoration: none;
  padding: 7px 10px;
  border-radius: 7px;
  font-size: 13px;
  line-height: 1;
  white-space: nowrap;
}
.nav a:hover, .nav a.active {
  color: var(--text);
  background: rgba(255,255,255,.08);
}
.tools {
  display: flex;
  gap: 8px;
}
.icon-btn {
  width: 36px;
  height: 36px;
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 7px;
  background: rgba(255,255,255,.06);
  color: var(--text);
}
.icon-btn:hover { background: rgba(255,255,255,.12); }

.progress {
  position: fixed;
  left: 0;
  top: var(--nav-h);
  width: 100%;
  height: 3px;
  z-index: 51;
  background: transparent;
}
.progress span {
  display: block;
  width: 0%;
  height: 100%;
  background: linear-gradient(90deg, var(--blue), var(--cyan), var(--gold));
}

main { padding-top: var(--nav-h); }
.section {
  min-height: calc(100vh - var(--nav-h));
  padding: clamp(72px, 12vh, 126px) clamp(18px, 5vw, 74px);
  display: grid;
  align-items: start;
  position: relative;
  scroll-margin-top: calc(var(--nav-h) + 18px);
}
.inner {
  width: min(100%, var(--max));
  margin: 0 auto;
  min-width: 0;
}
.hero {
  overflow: hidden;
  align-items: center;
}
.hero-grid {
  display: grid;
  grid-template-columns: 1.06fr .94fr;
  gap: clamp(28px, 6vw, 72px);
  align-items: center;
}
.eyebrow {
  color: var(--cyan);
  font-size: 13px;
  font-weight: 760;
  letter-spacing: .14em;
  text-transform: uppercase;
  margin: 0 0 18px;
}
h1, h2, h3, p { margin-top: 0; }
h1 {
  font-size: clamp(58px, 9vw, 132px);
  line-height: .9;
  letter-spacing: 0;
  margin-bottom: 26px;
}
h2 {
  font-size: clamp(36px, 5.4vw, 76px);
  line-height: 1.02;
  letter-spacing: 0;
  margin-bottom: 22px;
}
h3 {
  font-size: clamp(20px, 2vw, 28px);
  line-height: 1.22;
  letter-spacing: 0;
  margin-bottom: 12px;
}
.lead {
  font-size: clamp(20px, 2.4vw, 31px);
  line-height: 1.45;
  color: #ddd9cf;
  max-width: 760px;
}
.body {
  color: var(--muted);
  font-size: clamp(16px, 1.3vw, 19px);
  max-width: 760px;
}
.muted { color: var(--muted); }
.accent { color: var(--cyan); }
.blue { color: var(--blue); }
.gold { color: var(--gold); }
.red { color: var(--red); }

.stage-card {
  background: linear-gradient(180deg, rgba(255,255,255,.09), rgba(255,255,255,.045));
  border: 1px solid var(--line);
  border-radius: 8px;
  box-shadow: var(--shadow);
  padding: clamp(18px, 3vw, 34px);
}
.token-visual {
  min-height: 430px;
  position: relative;
  overflow: hidden;
}
.token-ring {
  position: absolute;
  inset: 44px;
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,.16);
  background:
    radial-gradient(circle, rgba(77,163,255,.18) 0 24%, transparent 25%),
    conic-gradient(from 140deg, rgba(77,163,255,.85), rgba(78,215,197,.75), rgba(240,184,79,.72), rgba(255,255,255,.18), rgba(77,163,255,.85));
  mask: radial-gradient(circle, transparent 0 42%, #000 43% 100%);
  -webkit-mask: radial-gradient(circle, transparent 0 42%, #000 43% 100%);
  animation: rotate 18s linear infinite;
}
.token-core {
  position: absolute;
  inset: 36%;
  border-radius: 50%;
  display: grid;
  place-items: center;
  background: rgba(5,6,9,.86);
  border: 1px solid rgba(255,255,255,.18);
  text-align: center;
}
.token-core strong {
  font-size: clamp(34px, 4vw, 56px);
  line-height: 1;
}
.chip-cloud {
  position: absolute;
  inset: 0;
}
.float-chip {
  position: absolute;
  padding: 7px 10px;
  border: 1px solid rgba(255,255,255,.13);
  border-radius: 7px;
  background: rgba(255,255,255,.07);
  color: #e9e5dc;
  font-size: 13px;
}
.float-chip:nth-child(1) { left: 4%; top: 15%; }
.float-chip:nth-child(2) { right: 8%; top: 17%; }
.float-chip:nth-child(3) { left: 10%; bottom: 18%; }
.float-chip:nth-child(4) { right: 2%; bottom: 26%; }
.float-chip:nth-child(5) { left: 39%; top: 5%; }
.float-chip:nth-child(6) { left: 42%; bottom: 6%; }

@keyframes rotate { to { transform: rotate(360deg); } }

.grid-3, .grid-4, .grid-2 {
  display: grid;
  gap: 14px;
}
.grid-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
.grid-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
.grid-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
.card {
  min-height: 116px;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 18px;
}
.card h3 { margin-bottom: 8px; }
.card p { color: var(--muted); margin-bottom: 0; }
.skill-link {
  color: var(--text);
  text-decoration: none;
  border-bottom: 1px solid rgba(78,215,197,.55);
}
.skill-link:hover { color: var(--cyan); }
.skill-link::after {
  content: "↗";
  margin-left: 6px;
  color: var(--cyan);
  font-size: .78em;
}
.tag {
  display: inline-flex;
  align-items: center;
  min-height: 24px;
  padding: 4px 8px;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 780;
  margin-bottom: 14px;
  background: rgba(77,163,255,.14);
  color: #a9d4ff;
}
.tag.green { background: rgba(116,216,137,.14); color: #a8edb5; }
.tag.gold { background: rgba(240,184,79,.16); color: #ffd889; }
.tag.red { background: rgba(255,111,97,.16); color: #ffafa7; }
.tag.violet { background: rgba(183,144,255,.16); color: #d8c6ff; }

.split {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 14px;
  margin-top: 22px;
}
.prompt-box {
  min-height: 178px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: #0a0d13;
  padding: 18px;
}
.prompt-box.bad { border-color: rgba(255,111,97,.28); }
.prompt-box.good { border-color: rgba(116,216,137,.32); }
.prompt-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 12px;
  font-weight: 760;
}
pre {
  margin: 0;
  white-space: pre-wrap;
  word-break: break-word;
  color: #ddd7c9;
  font-family: "SF Mono", Menlo, Monaco, Consolas, monospace;
  font-size: clamp(14px, 1.1vw, 16px);
  line-height: 1.68;
}

.pillars {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16px;
  margin-top: 30px;
}
.pillar {
  position: relative;
  min-height: 260px;
  padding: 22px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.035));
  overflow: hidden;
}
.pillar::after {
  content: attr(data-char);
  position: absolute;
  right: 12px;
  bottom: -18px;
  font-size: 112px;
  font-weight: 850;
  color: rgba(255,255,255,.055);
  line-height: 1;
}
.pillar h3 { color: var(--text); }
.pillar p { color: var(--muted); }

.chapter {
  display: grid;
  grid-template-columns: 92px minmax(0, 1fr);
  gap: clamp(18px, 4vw, 42px);
  align-items: start;
  min-width: 0;
}
.chapter > *, .content-stack { min-width: 0; }
.num {
  position: sticky;
  top: calc(var(--nav-h) + 30px);
  color: rgba(255,255,255,.12);
  font-size: clamp(54px, 7vw, 96px);
  line-height: .8;
  font-weight: 860;
}
.content-stack > * + * { margin-top: 24px; }
.quote {
  border-left: 2px solid var(--cyan);
  background: linear-gradient(90deg, rgba(78,215,197,.12), transparent);
  padding: 18px 22px;
  color: #eee9df;
  font-size: clamp(18px, 1.6vw, 23px);
  line-height: 1.55;
}
.profile-rule {
  border: 1px solid var(--line);
  border-radius: 8px;
  background: rgba(255,255,255,.035);
  padding: 16px;
}
.profile-rule h4 {
  margin: 0 0 8px;
  font-size: 16px;
  color: var(--text);
}
.profile-rule p { margin: 0; color: var(--muted); }
.layer-compare {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 72px minmax(0, 1fr);
  gap: 16px;
  align-items: stretch;
}
.layer-box {
  border: 1px solid var(--line);
  border-radius: 8px;
  background: rgba(255,255,255,.045);
  padding: 20px;
}
.layer-box h3 { margin-bottom: 8px; }
.layer-box ul {
  margin: 14px 0 0;
  padding-left: 20px;
  color: var(--muted);
}
.layer-box li + li { margin-top: 7px; }
.layer-arrow {
  display: grid;
  place-items: center;
  color: var(--cyan);
  font-size: 30px;
}
.product-list {
  display: grid;
  gap: 9px;
  margin-top: 16px;
}
.product-link {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  color: var(--text);
  text-decoration: none;
  border: 1px solid var(--line);
  border-radius: 7px;
  padding: 10px 12px;
  background: rgba(255,255,255,.035);
}
.product-link:hover {
  color: var(--cyan);
  border-color: rgba(78,215,197,.42);
}
.product-link small { color: var(--muted); }
.stack-flow {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 28px minmax(0, 1fr) 28px minmax(0, 1fr) 28px minmax(0, 1fr) 28px minmax(0, 1fr);
  gap: 8px;
  align-items: center;
}
.stack-node {
  min-height: 86px;
  display: grid;
  place-items: center;
  text-align: center;
  padding: 10px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: rgba(255,255,255,.045);
}
.stack-node strong { display: block; color: var(--text); }
.stack-node span { color: var(--muted); font-size: 13px; }
.stack-arrow { text-align: center; color: var(--cyan); }
.pairing-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}
.pairing-card {
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 16px;
  background: rgba(255,255,255,.035);
}
.pairing-card strong { display: block; margin-bottom: 7px; }
.pairing-card p { margin: 0; color: var(--muted); }
.profile-example {
  margin-top: 16px;
  border: 1px solid rgba(78,215,197,.22);
  border-radius: 8px;
  background: #0a0d13;
  padding: 16px;
}
.nested-window {
  margin-top: 16px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: #070a0f;
  overflow: hidden;
}
.window-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  min-height: 40px;
  padding: 0 14px;
  border-bottom: 1px solid var(--line);
  background: rgba(255,255,255,.055);
}
.window-dots {
  display: inline-flex;
  gap: 6px;
}
.window-dots i {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--red);
}
.window-dots i:nth-child(2) { background: var(--gold); }
.window-dots i:nth-child(3) { background: var(--green); }
.window-title {
  color: var(--text);
  font-weight: 760;
  font-size: 13px;
}
.scroll-window {
  max-height: 380px;
  min-height: 210px;
  resize: vertical;
  overflow: auto;
  padding: 16px;
  scrollbar-color: rgba(78,215,197,.7) rgba(255,255,255,.08);
  scrollbar-width: thin;
}
.scroll-window pre {
  color: #d8d1c3;
  font-size: clamp(13px, 1vw, 15px);
  line-height: 1.62;
}
.matrix {
  overflow-x: auto;
  border: 1px solid var(--line);
  border-radius: 8px;
  min-width: 0;
}
table {
  width: 100%;
  min-width: 720px;
  border-collapse: collapse;
  background: rgba(255,255,255,.035);
}
th, td {
  padding: 14px 16px;
  text-align: left;
  border-bottom: 1px solid rgba(255,255,255,.09);
  vertical-align: top;
}
th {
  color: #dfeaf7;
  font-size: 13px;
  letter-spacing: .08em;
  text-transform: uppercase;
}
td { color: var(--muted); }
tr:last-child td { border-bottom: 0; }

.tabbar {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin: 22px 0 14px;
}
.tab {
  border: 1px solid var(--line);
  border-radius: 7px;
  background: rgba(255,255,255,.05);
  color: var(--muted);
  padding: 8px 12px;
}
.tab.active {
  color: var(--text);
  background: rgba(77,163,255,.16);
  border-color: rgba(77,163,255,.42);
}
.panel { display: none; }
.panel.active { display: block; }

.token-lab {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(280px, .72fr);
  gap: 20px;
  align-items: stretch;
}
.allocator {
  display: grid;
  gap: 14px;
}
.alloc-row {
  display: grid;
  grid-template-columns: 96px minmax(0, 1fr) 48px;
  gap: 12px;
  align-items: center;
}
.alloc-row span {
  color: var(--muted);
  font-size: 14px;
}
input[type="range"] {
  width: 100%;
  accent-color: var(--cyan);
}
.token-meter {
  min-height: 34px;
  display: flex;
  overflow: hidden;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: rgba(255,255,255,.04);
}
.token-segment {
  min-width: 2px;
  transition: width .2s ease;
}
.seg-goal { background: var(--blue); }
.seg-context { background: var(--cyan); }
.seg-boundary { background: var(--gold); }
.seg-check { background: var(--green); }
.seg-noise { background: var(--red); }
.token-readout {
  border-radius: 8px;
  border: 1px solid var(--line);
  background: rgba(255,255,255,.045);
  padding: 18px;
}
.token-readout h4 {
  margin: 0 0 8px;
  font-size: 15px;
  color: var(--muted);
}
.token-readout strong {
  display: block;
  font-size: clamp(36px, 5vw, 60px);
  line-height: 1;
  margin-bottom: 12px;
}
.token-readout p {
  margin: 0;
  color: var(--muted);
}
.token-example {
  margin-top: 16px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: #0a0d13;
  padding: 14px;
}
.legend {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 12px;
}
.legend span {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: var(--muted);
  font-size: 13px;
}
.legend i {
  width: 10px;
  height: 10px;
  border-radius: 3px;
  display: inline-block;
}
.checklist {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  margin-top: 16px;
}
.check {
  display: flex;
  gap: 10px;
  align-items: flex-start;
  padding: 12px;
  border-radius: 8px;
  border: 1px solid var(--line);
  color: var(--muted);
  background: rgba(255,255,255,.035);
}
.check input { margin-top: 4px; }

.mini-label {
  color: var(--faint);
  font-size: 13px;
  font-weight: 760;
  letter-spacing: .08em;
  text-transform: uppercase;
  margin: 0 0 10px;
}
.choice-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
  margin-top: 16px;
}
.choice-btn {
  min-height: 72px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: rgba(255,255,255,.045);
  color: var(--muted);
  padding: 12px;
  text-align: left;
}
.choice-btn:hover, .choice-btn.active {
  color: var(--text);
  border-color: rgba(78,215,197,.48);
  background: rgba(78,215,197,.11);
}
.choice-btn.correct {
  border-color: rgba(116,216,137,.6);
  background: rgba(116,216,137,.12);
  color: var(--text);
}
.choice-btn.wrong {
  border-color: rgba(255,111,97,.55);
  background: rgba(255,111,97,.1);
  color: var(--text);
}
.result-panel {
  margin-top: 16px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: rgba(255,255,255,.045);
  padding: 16px;
  color: var(--muted);
}
.result-panel strong {
  display: block;
  color: var(--text);
  font-size: clamp(22px, 2.4vw, 32px);
  line-height: 1.12;
  margin-bottom: 8px;
}
.builder-grid, .sort-grid, .project-grid {
  display: grid;
  grid-template-columns: minmax(0, .9fr) minmax(0, 1.1fr);
  gap: 16px;
  align-items: stretch;
}
.chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.build-chip {
  border: 1px solid var(--line);
  border-radius: 7px;
  background: rgba(255,255,255,.055);
  color: var(--muted);
  padding: 9px 11px;
  text-align: left;
}
.build-chip:hover, .build-chip.active {
  border-color: rgba(77,163,255,.5);
  background: rgba(77,163,255,.13);
  color: var(--text);
}
.build-chip.required.active {
  border-color: rgba(116,216,137,.58);
  background: rgba(116,216,137,.13);
}
.toolbar-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 12px;
}
.plain-btn {
  border: 1px solid var(--line);
  border-radius: 7px;
  background: rgba(255,255,255,.055);
  color: var(--muted);
  padding: 8px 11px;
}
.plain-btn:hover {
  color: var(--text);
  background: rgba(255,255,255,.1);
}
.output-box {
  min-height: 100%;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: #0a0d13;
  padding: 16px;
}
.output-box pre { color: #e6dfcf; }
.context-stage {
  display: grid;
  grid-template-columns: minmax(0, .8fr) minmax(0, 1.2fr);
